<ContentPage
    x:Class="TourGuideApp2.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="{StaticResource Background}">

    <ScrollView>

        <VerticalStackLayout Padding="20" Spacing="20">

            <Border
                BackgroundColor="#FF6200"
                StrokeShape="RoundRectangle 14"
                Padding="14,10"
                HorizontalOptions="Center">
                <Label
                    Text="Xin chào phố ẩm thực Vĩnh Khánh :)"
                    FontSize="16"
                    FontAttributes="Bold"
                    TextColor="White"
                    HorizontalTextAlignment="Center" />
            </Border>

            <Label
                Text="📍 Phố Ẩm Thực Vĩnh Khánh"
                FontSize="28"
                FontAttributes="Bold"
                HorizontalOptions="Center"
                TextColor="{StaticResource Primary}" />

            <Label
                Text="Ứng dụng thuyết minh tự động"
                FontSize="18"
                HorizontalOptions="Center"
                TextColor="#37474F"/>

            <Label
                Text="Khám phá thiên đường hải sản tại Quận 4, TP.HCM."
                FontSize="16"
                TextColor="#455A64"/>

            <Border
                BackgroundColor="White"
                Stroke="#E0E0E0"
                StrokeThickness="1"
                Padding="12">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Dùng app trực tiếp"
                           FontAttributes="Bold"
                           FontSize="18"
                           TextColor="#0D47A1" />
                    <Label Text="Không cần đăng nhập. Chọn tab Bản đồ để xem POI và nghe thuyết minh. App tự đồng bộ dữ liệu khi mở; lượt nghe lưu trên máy và gửi lên CMS khi tới được máy chủ. Quản lý khách hàng vẫn trên web CMS."
                           FontSize="13"
                           TextColor="#546E7A"
                           LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Border>

            <Border
                BackgroundColor="White"
                StrokeThickness="1"
                Padding="15">

                <VerticalStackLayout>

                    <Label
                        Text="🦑 Ốc Đào"
                        FontAttributes="Bold"
                        FontSize="18"/>

                    <Label
                        Text="Quán ốc nổi tiếng nhất tại phố ẩm thực Vĩnh Khánh." />

                </VerticalStackLayout>

            </Border>

            <Border
                BackgroundColor="White"
                StrokeThickness="1"
                Padding="15">

                <VerticalStackLayout>

                    <Label
                        Text="🦐 Hải sản nướng"
                        FontAttributes="Bold"
                        FontSize="18"/>

                    <Label
                        Text="Nhiều quán hải sản tươi sống chế biến tại chỗ." />

                </VerticalStackLayout>

            </Border>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>