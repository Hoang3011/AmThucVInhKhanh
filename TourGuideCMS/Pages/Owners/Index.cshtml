@page
@model TourGuideCMS.Pages.Owners.IndexModel
@{
    ViewData["Title"] = "Tài khoản chủ quán";
}

<h1>Tài khoản chủ quán theo POI</h1>
<p class="text-muted small">
    Mỗi POI có 1 tài khoản chủ quán mặc định: <code>owner&lt;PlaceId&gt;</code> / <code>poi&lt;PlaceId&gt;@@123</code>.
    Khi xóa POI, tài khoản chủ quán tương ứng sẽ bị vô hiệu hóa.
</p>

@if (!string.IsNullOrWhiteSpace(Model.Toast))
{
    <div class="alert alert-info">@Model.Toast</div>
}

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead>
            <tr>
                <th>POI Id</th>
                <th>Địa điểm</th>
                <th>Tài khoản chủ quán</th>
                <th>Mật khẩu</th>
                <th>Trạng thái</th>
                <th>Cập nhật</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var r in Model.Rows)
        {
            <tr>
                <td>@r.PlaceId</td>
                <td>@r.PlaceName</td>
                <td><code>@r.Username</code></td>
                <td><code>@r.Password</code></td>
                <td>
                    @if (r.IsActive)
                    {
                        <span class="badge bg-success">Đang hoạt động</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Đã vô hiệu hóa</span>
                    }
                </td>
                <td>@(r.UpdatedAtUtc?.ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                <td class="text-nowrap">
                    <form method="post" asp-page-handler="Toggle" class="d-inline">
                        <input type="hidden" name="placeId" value="@r.PlaceId" />
                        <button type="submit" class="btn btn-outline-primary btn-sm">@((r.IsActive) ? "Khóa" : "Mở")</button>
                    </form>
                    <form method="post" asp-page-handler="ResetPassword" class="d-inline">
                        <input type="hidden" name="placeId" value="@r.PlaceId" />
                        <button type="submit" class="btn btn-outline-warning btn-sm">Reset mật khẩu</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
