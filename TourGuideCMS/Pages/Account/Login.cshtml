@page
@model TourGuideCMS.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Đăng nhập CMS";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <h2 class="mb-3">CMS — Phố ẩm thực Vĩnh Khánh</h2>
        <p class="text-muted small">Đăng nhập bằng tài khoản Admin hoặc Chủ quán.</p>
        <p class="text-muted small">Admin mặc định: <code>admin</code> / <code>admin123</code> (hoặc mật khẩu từ cấu hình <code>AdminPassword</code>).</p>
        <form method="post">
            <div class="mb-3">
                <label class="form-label">Tài khoản</label>
                <input type="text" class="form-control" asp-for="Username" autocomplete="username" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Mật khẩu</label>
                <input type="password" class="form-control" asp-for="Password" autocomplete="current-password" required />
            </div>
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger">@Model.ErrorMessage</div>
            }
            <button type="submit" class="btn btn-primary">Đăng nhập</button>
        </form>
    </div>
</div>
