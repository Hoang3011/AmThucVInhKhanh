@page
@model TourGuideCMS.Pages.Devices.OnlineModel
@{
    ViewData["Title"] = "Thiết bị đang online";
}

<h1 class="mb-3">Thiết bị — tab Bản đồ</h1>

<p class="text-muted">
    <strong>Online</strong> = app đang ở tab <strong>Bản đồ</strong> và vừa gửi ping trong <strong>@Model.OnlineWindowSeconds</strong> giây (UTC).
    Khi chuyển sang tab khác, app báo <em>offline</em> ngay. Nếu app tắt đột ngột trên bản đồ, sau @Model.OnlineWindowSeconds giây không có ping thì CMS cũng hiển thị offline.
    Cần app cấu hình đúng URL CMS và (nếu có) khóa <code>X-Mobile-Key</code>.
</p>

<div class="alert alert-info py-2 mb-3">
    <strong>Đang online (tab Bản đồ):</strong> @Model.OnlineCount
    <span class="ms-3"><strong>Offline (trong danh sách dưới):</strong> @Model.OfflineCount</span>
    <span class="ms-2 small">(mốc UTC: @Model.CutoffUtc.ToString("O"))</span>
</div>

@if (Model.Devices.Count == 0)
{
    <p>Chưa có thiết bị nào gửi heartbeat. Mở app → tab <strong>Bản đồ</strong> (có mạng tới CMS) rồi tải lại trang.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-sm align-middle">
            <thead>
                <tr>
                    <th>Trạng thái</th>
                    <th>Mã thiết bị</th>
                    <th>Lần cuối (UTC)</th>
                    <th>Nền tảng</th>
                    <th>Phiên bản app</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var d in Model.Devices)
            {
                var online = Model.IsRowOnlineOnMap(d);
                <tr>
                    <td>
                        @if (online)
                        {
                            <span class="badge bg-success">Online</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Offline</span>
                        }
                    </td>
                    <td><code class="small">@d.DeviceInstallId</code></td>
                    <td>@d.LastSeenUtc.ToString("yyyy-MM-dd HH:mm:ss")</td>
                    <td>@(d.Platform ?? "—")</td>
                    <td>@(d.AppVersion ?? "—")</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}

<p class="mt-3">
    <a class="btn btn-outline-secondary btn-sm" asp-page="/Index">Về trang chủ</a>
    <button type="button" class="btn btn-primary btn-sm" onclick="location.reload()">Tải lại</button>
</p>
