@page
@model IndexModel
@{
    ViewData["Title"] = "Trang chủ CMS";
}

<h1 class="mb-3">Quản trị nội dung — Vĩnh Khánh</h1>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">POI</h5>
                <p class="display-6">@Model.PlaceCount</p>
                <a class="btn btn-outline-primary" asp-page="/Places/Index">Quản lý danh sách</a>
            </div>
        </div>
    </div>
    <div class="col-md-8">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">API cho app MAUI</h5>
                <p class="small mb-1">Endpoint đọc POI (JSON):</p>
                <code class="d-block mb-2 p-2 bg-light">GET @Request.Scheme://@Request.Host/api/places</code>
                <p class="small text-muted mb-0">Trong app: cài <strong>Preferences</strong> URL API = địa chỉ trên (máy thật: IP LAN máy chạy web). File DB: <code class="small">@Model.DatabasePath</code></p>
            </div>
        </div>
    </div>
</div>

<div class="mt-4">
    <a class="btn btn-link" asp-page="/Reports">Lịch sử / Tour — gợi ý</a>
</div>

<!-- Ô mới: QR Code tải app (đặt ngay dưới phần lịch sử) -->
<div class="mt-4">
    <div class="card">
        <div class="card-body text-center py-4">
            <h5 class="card-title mb-3">Tải app MAUI</h5>
            
            <!-- === CHỖ NÀY ĐỂ BẠN CHÈN HÌNH QR === -->
            <!-- Thay src bằng đường dẫn thực tế của file QR (ví dụ: /images/qr-maui-app.png) -->
            <img src="/Resources/QR.png"
                 alt="QR Code tải ứng dụng MAUI"
                 class="img-fluid shadow-sm"
                 style="max-width: 260px; border: 1px solid #dee2e6; border-radius: 12px;">
            
            <p class="small text-muted mt-3 mb-0">
                Quét mã QR bằng điện thoại để tải ngay ứng dụng<br>
                (Hoặc mở link API phía trên trong app)
            </p>
        </div>
    </div>
</div>