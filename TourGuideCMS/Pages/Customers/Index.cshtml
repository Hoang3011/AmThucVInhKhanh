@page
@model TourGuideCMS.Pages.Customers.IndexModel
@{
    ViewData["Title"] = "Khách hàng (app)";
}

<h1>Khách hàng đăng ký qua app</h1>
<p class="text-muted small">
    Tài khoản được tạo khi app gọi <code>POST /api/customers/register</code> (cùng host với API POI).
    Cột mật khẩu hiển thị theo dữ liệu đăng ký từ app (để tiện quản lý).
    Với tài khoản cũ tạo trước khi có cột này, mật khẩu sẽ tự hiện sau lần đăng nhập thành công tiếp theo.
</p>

<table class="table table-sm table-striped">
    <thead>
        <tr>
            <th>Id</th>
            <th>Họ tên</th>
            <th>Email / SĐT</th>
            <th>Mật khẩu</th>
            <th>Ngày tạo (UTC)</th>
            <th>Tuyến / Heatmap (theo tài khoản)</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var u in Model.Users)
    {
        <tr>
            <td>@u.Id</td>
            <td>@u.FullName</td>
            <td>@u.PhoneOrEmail</td>
            <td>@(string.IsNullOrWhiteSpace(u.PasswordPlain) ? "—" : u.PasswordPlain)</td>
            <td>@u.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
            <td>
                <a asp-page="/Customers/Route" asp-route-id="@u.Id">Tuyến</a>
                ·
                <a asp-page="/Customers/Heatmap" asp-route-id="@u.Id">Heatmap</a>
            </td>
        </tr>
    }
    </tbody>
</table>

@if (Model.Users.Count == 0)
{
    <p class="alert alert-light border">Chưa có tài khoản nào đồng bộ từ app.</p>
}

<h2 class="h4 mt-4">Thiết bị đồng bộ từ app</h2>
<p class="text-muted small">
    Theo dõi theo từng thiết bị để quản lý đa máy: tuyến đường, heatmap, và lịch sử phát được gắn theo <code>deviceInstallId</code>.
</p>
<table class="table table-sm table-striped">
    <thead>
        <tr>
            <th>Tên thiết bị</th>
            <th>Mã thiết bị</th>
            <th>Khách liên kết</th>
            <th>Nền tảng/App</th>
            <th>Cập nhật gần nhất (UTC)</th>
            <th>Tuyến / Heatmap</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var d in Model.Devices)
    {
        <tr>
            <td>@d.DeviceName</td>
            <td><code>@d.DeviceInstallId</code></td>
            <td>@(string.IsNullOrWhiteSpace(d.CustomerPhoneOrEmail) ? "—" : $"{d.CustomerFullName} ({d.CustomerPhoneOrEmail})")</td>
            <td>@(d.Platform ?? "-") / @(d.AppVersion ?? "-")</td>
            <td>@(d.LastSeenUtc?.ToUniversalTime().ToString("yyyy-MM-dd HH:mm") ?? d.RouteUpdatedAtUtc.ToUniversalTime().ToString("yyyy-MM-dd HH:mm"))</td>
            <td>
                <a asp-page="/Customers/Route" asp-route-deviceInstallId="@d.DeviceInstallId">Tuyến</a>
                ·
                <a asp-page="/Customers/Heatmap" asp-route-deviceInstallId="@d.DeviceInstallId">Heatmap</a>
            </td>
        </tr>
    }
    </tbody>
</table>

@if (Model.Devices.Count == 0)
{
    <p class="alert alert-light border">Chưa có thiết bị nào đồng bộ tuyến từ app.</p>
}

<p><a asp-page="/Index">← Trang chủ</a></p>
