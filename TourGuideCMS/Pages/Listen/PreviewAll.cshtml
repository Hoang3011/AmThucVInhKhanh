@page "/Listen/PreviewAll"
@model TourGuideCMS.Pages.Listen.PreviewAllModel
@{
    Layout = "_LayoutPublic";
    ViewData["Title"] = "Nghe thử tất cả quán";
}

<div class="container py-3" style="max-width: 980px;">
    <h3 class="mb-2">Nghe thử thuyết minh tất cả quán</h3>
    <p class="small text-muted mb-3">
        Mỗi thiết bị được nghe tối đa <strong>3 lần / ngôn ngữ / quán</strong> (đếm trên trình duyệt này). Khi hết lượt, vui lòng tải app để nghe không giới hạn.
        <span class="d-block mt-1">Sau khi đã tải trang <strong>ít nhất một lần khi máy chủ còn bật</strong>, bạn vẫn có thể mở lại và nghe thuyết minh khi tắt CMS hoặc mất mạng (cùng thiết bị, cùng trình duyệt đã lưu bản sao trang).</span>
    </p>
    <div id="previewAlert" class="alert alert-info py-2 small d-none"></div>

    <div class="row g-3">
        @foreach (var p in Model.Places)
        {
            <div class="col-12 col-md-6">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title mb-1">@p.Name</h5>
                        <div class="small text-muted mb-2">@p.Address</div>
                        <div class="d-flex flex-wrap gap-2">
                            <button type="button" class="btn btn-outline-primary btn-sm" onclick="listen(@p.Id, 'vi')">Nghe tiếng Việt</button>
                            <button type="button" class="btn btn-outline-primary btn-sm" onclick="listen(@p.Id, 'en')">Listen English</button>
                            <button type="button" class="btn btn-outline-primary btn-sm" onclick="listen(@p.Id, 'zh')">中文</button>
                            <button type="button" class="btn btn-outline-primary btn-sm" onclick="listen(@p.Id, 'ja')">日本語</button>
                        </div>
                        <div id="text-@p.Id" class="small mt-2" style="white-space:pre-wrap"></div>
                        <div id="remain-@p.Id" class="small text-secondary mt-2"></div>
                    </div>
                </div>
            </div>
        }
    </div>

    <hr class="my-4" />
    <div class="text-center">
        <h5 class="mb-2">Tải app để nghe bản không giới hạn</h5>
        <img src="/Resources/QR.png" alt="QR tải app" class="img-fluid shadow-sm" style="max-width:260px;border:1px solid #dee2e6;border-radius:12px;" />
        <p class="small mt-2 mb-0">Hoặc mở trực tiếp: <a href="@Model.AppInstallUrl">@Model.AppInstallUrl</a></p>
    </div>
</div>

<script id="preview-poi-json" type="application/json">@Html.Raw(Model.PlacesJson)</script>

@section Scripts {
    <script>
        (function () {
            var key = 'vk_web_preview_did';
            var id = localStorage.getItem(key);
            if (!id) {
                try { id = crypto.randomUUID(); } catch (e) { id = 'w' + Math.random().toString(36).slice(2) + Date.now(); }
                localStorage.setItem(key, id);
            }
            window.webPreviewDeviceId = id;
        })();

        var PREVIEW_POIS = [];
        (function loadPois() {
            var el = document.getElementById('preview-poi-json');
            if (!el || !el.textContent) return;
            try { PREVIEW_POIS = JSON.parse(el.textContent); } catch (e) { PREVIEW_POIS = []; }
        })();

        function previewCountKey(placeId, lang) {
            return 'vk_pv_cnt_v1_' + placeId + '_' + (lang || '').toLowerCase();
        }

        function getPlayCount(placeId, lang) {
            var v = localStorage.getItem(previewCountKey(placeId, lang));
            var n = parseInt(v || '0', 10);
            return isNaN(n) ? 0 : n;
        }

        function setPlayCount(placeId, lang, n) {
            localStorage.setItem(previewCountKey(placeId, lang), String(Math.max(0, n)));
        }

        function findPlace(placeId) {
            for (var i = 0; i < PREVIEW_POIS.length; i++) {
                if (PREVIEW_POIS[i].id === placeId) return PREVIEW_POIS[i];
            }
            return null;
        }

        function resolvePreviewText(place, lang) {
            var language = (lang || 'vi').trim().toLowerCase();
            var text = '';
            if (language === 'vi') text = place.vi || '';
            else if (language === 'en') text = place.en || '';
            else if (language === 'zh') text = place.zh || '';
            else if (language === 'ja') text = place.ja || '';
            if (!text || !String(text).trim()) {
                var v = place.vi && String(place.vi).trim();
                text = v ? place.vi : (place.desc || '');
            }
            return String(text || '').trim();
        }

        function speakText(text, language) {
            if (!window.speechSynthesis) return false;
            window.speechSynthesis.cancel();
            var u = new SpeechSynthesisUtterance(text);
            u.lang = language === 'vi' ? 'vi-VN'
                : language === 'en' ? 'en-US'
                : language === 'zh' ? 'zh-CN'
                : language === 'ja' ? 'ja-JP'
                : 'vi-VN';
            window.speechSynthesis.speak(u);
            return true;
        }

        function tryLogPlayToServer(placeId, language) {
            if (!navigator.onLine || !window.webPreviewDeviceId) return;
            var payload = JSON.stringify({
                placeId: placeId,
                language: language,
                deviceInstallId: window.webPreviewDeviceId
            });
            fetch('/api/listen/preview/play', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: payload,
                keepalive: true
            }).catch(function () { });
        }

        function updateRemainForPlace(placeId) {
            var remainEl = document.getElementById('remain-' + placeId);
            if (!remainEl) return;
            var vi = Math.max(0, 3 - getPlayCount(placeId, 'vi'));
            var en = Math.max(0, 3 - getPlayCount(placeId, 'en'));
            var zh = Math.max(0, 3 - getPlayCount(placeId, 'zh'));
            var ja = Math.max(0, 3 - getPlayCount(placeId, 'ja'));
            remainEl.textContent = 'Còn lượt trên trình duyệt này — Vi: ' + vi + ' · En: ' + en + ' · 中: ' + zh + ' · 日: ' + ja + ' (mỗi cột tối đa 3).';
        }

        document.addEventListener('DOMContentLoaded', function () {
            for (var i = 0; i < PREVIEW_POIS.length; i++) {
                updateRemainForPlace(PREVIEW_POIS[i].id);
            }
        });

        async function listen(placeId, language) {
            var alertBox = document.getElementById('previewAlert');
            var place = findPlace(placeId);
            if (!place) {
                alertBox.className = 'alert alert-warning py-2 small';
                alertBox.classList.remove('d-none');
                alertBox.textContent = 'Không tìm thấy dữ liệu quán trên trang.';
                return;
            }

            var used = getPlayCount(placeId, language);
            if (used >= 3) {
                alertBox.className = 'alert alert-warning py-2 small';
                alertBox.classList.remove('d-none');
                alertBox.textContent = 'Đã hết 3 lượt nghe thử cho ngôn ngữ này trên thiết bị này. Vui lòng tải app để nghe không giới hạn.';
                updateRemainForPlace(placeId);
                return;
            }

            var text = resolvePreviewText(place, language);
            if (!text) {
                alertBox.className = 'alert alert-warning py-2 small';
                alertBox.classList.remove('d-none');
                alertBox.textContent = 'POI chưa có nội dung cho ngôn ngữ này.';
                return;
            }

            setPlayCount(placeId, language, used + 1);
            var remaining = Math.max(0, 3 - getPlayCount(placeId, language));

            var textEl = document.getElementById('text-' + placeId);
            if (textEl) textEl.textContent = text;

            var spoken = speakText(text, language);
            alertBox.className = 'alert alert-success py-2 small';
            alertBox.classList.remove('d-none');
            alertBox.textContent = (spoken ? 'Đang phát: ' : 'Đã hiển thị nội dung: ')
                + (place.name || '') + ' (' + language + '). Còn ' + remaining + ' lượt.';

            updateRemainForPlace(placeId);
            tryLogPlayToServer(placeId, language);
        }

        if ('serviceWorker' in navigator) {
            window.addEventListener('load', function () {
                navigator.serviceWorker.register('/vk-preview-sw.js').catch(function () { });
            });
        }
    </script>
}
