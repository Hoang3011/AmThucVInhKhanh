@page
@model TourGuideCMS.Pages.Places.IndexModel
@{
    ViewData["Title"] = "Danh sách POI";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Điểm thuyết minh (POI)</h1>
    <a class="btn btn-primary" asp-page="Create">Thêm POI</a>
</div>

<div class="card mb-3">
    <div class="card-body d-flex flex-wrap gap-3 align-items-center">
        <img src="@Model.PublicPreviewQrImageSrc" alt="QR nghe thử tất cả quán" style="width:110px;height:110px;border:1px solid #dee2e6;border-radius:10px;padding:6px;background:#fff;" />
        <div>
            <h6 class="mb-1">QR nghe thử tất cả quán</h6>
            <div class="small text-muted mb-1">1 mã duy nhất cho khách: vào trang nghe thử tất cả POI và tất cả ngôn ngữ.</div>
            <a href="@Model.PublicPreviewAllUrl" target="_blank" rel="noopener">@Model.PublicPreviewAllUrl</a>
        </div>
    </div>
</div>

<table class="table table-striped table-sm">
    <thead>
        <tr>
            <th>Id</th>
            <th>Tên</th>
            <th>Ưu tiên</th>
            <th>Lượt vào quán</th>
            <th>Tọa độ</th>
            <th>Bán kính (m)</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var p in Model.Places)
    {
        <tr>
            <td>@p.Id</td>
            <td>@p.Name</td>
            <td>@p.Priority</td>
            <td>
                @{
                    var visits = Model.VisitCountByPlaceId.TryGetValue(p.Id, out var cnt) ? cnt : 0;
                }
                <strong>@visits</strong>
                @if (visits > 0 && visits == Model.HighestVisitCount)
                {
                    <span class="badge text-bg-success ms-1">Nhiều nhất</span>
                }
            </td>
            <td>@p.Latitude.ToString("F5"), @p.Longitude.ToString("F5")</td>
            <td>@p.ActivationRadiusMeters</td>
            <td>
                <a asp-page="Heatmap" asp-route-id="@p.Id">Heatmap</a> |
                <a asp-page="Edit" asp-route-id="@p.Id">Sửa</a> |
                <a asp-page="Delete" asp-route-id="@p.Id" class="text-danger">Xóa</a>
            </td>
        </tr>
    }
    </tbody>
</table>
